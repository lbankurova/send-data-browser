{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sendex.local/baseline.schema.json",
  "title": "Approval-test baseline (F4)",
  "description": "Per-study analytical-output snapshot. See backend/tests/approval-baselines/README.md for the cut-line between scientific (commit-blocking on diff) and presentation (auto-approve, log-only) tiers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "study_id",
    "captured_at",
    "captured_against_commit",
    "captured_from",
    "captured_by",
    "scientific",
    "presentation"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Bump on schema change with one-shot migration of all existing captures (per README versioning section)."
    },
    "study_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable study identifier matching backend/generated/{study_id}/."
    },
    "captured_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of capture."
    },
    "captured_against_commit": {
      "type": "string",
      "minLength": 7,
      "description": "Short commit hash of HEAD at capture time."
    },
    "captured_from": {
      "type": "string",
      "minLength": 1,
      "description": "Source path the capture script read (typically backend/generated/{study_id}/unified_findings.json)."
    },
    "captured_by": {
      "type": "string",
      "minLength": 1,
      "description": "Capture script path. Today: scripts/capture-approval-baseline.py (F4 Phase 1)."
    },
    "scientific": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary_counts",
        "noael_per_endpoint_sex",
        "adverse_classification",
        "target_organs",
        "syndrome_detections",
        "signal_scores",
        "effect_sizes",
        "p_value_adjustments",
        "eci_dimensions"
      ],
      "properties": {
        "summary_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total_findings",
            "total_adverse",
            "total_warning",
            "total_normal",
            "total_treatment_related"
          ],
          "properties": {
            "total_findings": {"type": "integer", "minimum": 0},
            "total_adverse": {"type": "integer", "minimum": 0},
            "total_warning": {"type": "integer", "minimum": 0},
            "total_normal": {"type": "integer", "minimum": 0},
            "total_treatment_related": {"type": "integer", "minimum": 0}
          }
        },
        "noael_per_endpoint_sex": {
          "type": "object",
          "description": "Keyed by '{domain}.{test_code}.{specimen}.{sex}' (4 segments, no day -- NOAEL aggregates across days).",
          "patternProperties": {
            "^[A-Z]+\\.[^.]*\\.[^.]*\\.[MF]$": {
              "type": "object",
              "additionalProperties": false,
              "required": ["tier", "value", "loael"],
              "properties": {
                "tier": {
                  "type": "string",
                  "enum": ["high", "low", "below_tested", "above_tested", "insufficient_evidence"]
                },
                "value": {"type": ["string", "null"]},
                "loael": {"type": ["string", "null"]}
              }
            }
          },
          "additionalProperties": false
        },
        "adverse_classification": {
          "type": "object",
          "description": "Keyed by finding_id ({domain}.{test_code}.{specimen}.{sex}.{day}, 5 segments, empty string for null).",
          "patternProperties": {
            "^[A-Z]+\\.[^.]*\\.[^.]*\\.[^.]*\\.[^.]*$": {
              "type": "object",
              "additionalProperties": false,
              "required": ["verdict", "treatment_related", "severity"],
              "properties": {
                "verdict": {"type": ["string", "null"]},
                "treatment_related": {"type": ["boolean", "null"]},
                "severity": {"type": ["string", "null"]}
              }
            }
          },
          "additionalProperties": false
        },
        "target_organs": {
          "type": "array",
          "description": "Sorted alphabetically for stable serialization.",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "syndrome_detections": {
          "type": "array",
          "description": "Sorted by syndrome_id for stable serialization.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["syndrome_id", "certainty", "evidence_count"],
            "properties": {
              "syndrome_id": {"type": "string", "minLength": 1},
              "certainty": {
                "type": "string",
                "enum": ["confirmed", "likely", "possible", "uncertain"]
              },
              "evidence_count": {"type": "integer", "minimum": 0},
              "species_required": {"type": ["string", "null"]}
            }
          }
        },
        "signal_scores": {
          "type": "object",
          "description": "Per-finding numeric signal score; key matches finding_id pattern.",
          "patternProperties": {
            "^[A-Z]+\\.[^.]*\\.[^.]*\\.[^.]*\\.[^.]*$": {
              "type": ["number", "null"]
            }
          },
          "additionalProperties": false
        },
        "effect_sizes": {
          "type": "object",
          "description": "Per-finding max_effect_size; key matches finding_id pattern.",
          "patternProperties": {
            "^[A-Z]+\\.[^.]*\\.[^.]*\\.[^.]*\\.[^.]*$": {
              "type": ["number", "null"]
            }
          },
          "additionalProperties": false
        },
        "p_value_adjustments": {
          "type": "object",
          "description": "Per-finding min_p_adj; key matches finding_id pattern.",
          "patternProperties": {
            "^[A-Z]+\\.[^.]*\\.[^.]*\\.[^.]*\\.[^.]*$": {
              "type": ["number", "null"]
            }
          },
          "additionalProperties": false
        },
        "eci_dimensions": {
          "type": "object",
          "description": "Per-finding ECI dimensions D1-D9.",
          "patternProperties": {
            "^[A-Z]+\\.[^.]*\\.[^.]*\\.[^.]*\\.[^.]*$": {
              "type": "object",
              "additionalProperties": false,
              "patternProperties": {
                "^D[1-9]$": {"type": ["number", "null"]}
              }
            }
          },
          "additionalProperties": false
        }
      }
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Auto-approve tier. Diffs here are logged to .lattice/approval-log.tsv but never block.",
      "properties": {
        "labels": {
          "type": "object",
          "description": "Display label strings keyed by their semantic identifier."
        },
        "format_strings": {
          "type": "object",
          "description": "Format / unit / template strings."
        },
        "bundle_artifacts": {
          "type": "object",
          "description": "Build-artifact sizes and counts.",
          "additionalProperties": {"type": ["integer", "string", "null"]}
        }
      }
    }
  }
}
