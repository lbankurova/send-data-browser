        },
        {
          "tag": "HEPATIC_HYPERTROPHY",
          "domain": "MI",
          "specimenTerms": {
            "specimen": ["liver", "hepat"],
            "finding": ["hypertrophy", "hepatocellular hypertrophy", "centrilobular hypertrophy"]
