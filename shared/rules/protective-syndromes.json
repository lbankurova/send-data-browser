    {
      "syndromeId": "R18",
      "name": "Adaptive Hepatic Enzyme Induction Syndrome",
      "category": "A",
      "direction": "decreasing",
      "minDomains": 2,
      "requiredLogic": {
        "type": "compound",
        "expression": "(LIVER_WT AND HEPATIC_HYPERTROPHY) AND NOT XS01_REQUIRED AND NOT XS02_REQUIRED AND NOT ALT_2X AND NOT AST_2X"
