                  { "type": "direction", "canonical": "ALT", "direction": "up" },
                  { "type": "share_sex", "canonical_a": "ALT", "canonical_b": "TBILI" }
                ]
              },
              {
                "type": "and",
                "conditions": [
                  { "type": "direction", "canonical": "AST", "direction": "up" },
                  { "type": "share_sex", "canonical_a": "AST", "canonical_b": "TBILI" }
                ]
              }
            ]
          }
        ]
      }
