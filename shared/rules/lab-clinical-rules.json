{
  "$schema": "../schemas/lab-clinical-rules.schema.json",
  "version": "2.0.0",
  "rules": [
    {
      "id": "L01", "name": "ALT elevation (moderate)", "category": "liver",
      "parameters": [{ "canonical": "ALT", "direction": "increase", "role": "required" }],
      "severity": "S2", "species_applicability": "both", "source": "FDA Guidance (2009)",
      "thresholds": { "ALT": { "value": 2, "comparison": "gte" } },
      "baseline_aware": true,
      "applies_to_study_types": ["REPEAT_DOSE_*", "ACUTE", "DOSE_RANGE_FINDER"],
      "condition_type": "graded_increase",
      "conditions": {
        "type": "and",
        "conditions": [
          { "type": "direction", "canonical": "ALT", "direction": "up" },
          { "type": "fold_between", "canonical": "ALT", "gte": 2, "lt": 5 }
        ]
      }
    },
    {
      "id": "L02", "name": "ALT elevation (marked)", "category": "liver",
      "parameters": [{ "canonical": "ALT", "direction": "increase", "role": "required" }],
      "severity": "S3", "species_applicability": "both", "source": "FDA Guidance (2009)",
      "thresholds": { "ALT": { "value": 5, "comparison": "gte" } },
      "baseline_aware": true,
      "applies_to_study_types": ["REPEAT_DOSE_*", "ACUTE", "DOSE_RANGE_FINDER"],
      "condition_type": "graded_increase",
      "conditions": {
        "type": "and",
        "conditions": [
          { "type": "direction", "canonical": "ALT", "direction": "up" },
          { "type": "fold_above", "canonical": "ALT", "threshold": 5 }
        ]
      }
    },
    {
      "id": "L03", "name": "ALT + Bilirubin concurrent elevation", "category": "liver",
      "parameters": [
        { "canonical": "ALT", "direction": "increase", "role": "required" },
        { "canonical": "TBILI", "direction": "increase", "role": "required" }
      ],
      "severity": "S4", "species_applicability": "both", "source": "FDA Guidance (2009), Hy's Law",
      "baseline_aware": true,
      "applies_to_study_types": ["REPEAT_DOSE_*", "ACUTE", "DOSE_RANGE_FINDER"],
      "condition_type": "custom",
      "conditions": {
        "type": "and",
        "conditions": [
          { "type": "direction", "canonical": "ALT", "direction": "up" },
          { "type": "direction", "canonical": "TBILI", "direction": "up" },
          { "type": "share_sex", "canonical_a": "ALT", "canonical_b": "TBILI" }
        ]
      }
    },
    {
      "id": "L04", "name": "Bilirubin elevation (isolated)", "category": "liver",
      "parameters": [{ "canonical": "TBILI", "direction": "increase", "role": "required" }],
      "severity": "S1", "species_applicability": "both", "source": "Clinical practice",
      "baseline_aware": true,
      "applies_to_study_types": ["REPEAT_DOSE_*", "ACUTE", "DOSE_RANGE_FINDER"],
      "condition_type": "custom",
      "conditions": {
        "type": "and",
        "conditions": [
          { "type": "direction", "canonical": "TBILI", "direction": "up" },
          { "type": "not", "condition": { "type": "direction", "canonical": "ALT", "direction": "up" } },
          { "type": "not", "condition": { "type": "direction", "canonical": "AST", "direction": "up" } },
          { "type": "not", "condition": { "type": "direction", "canonical": "ALP", "direction": "up" } },
          { "type": "not", "condition": { "type": "direction", "canonical": "GGT", "direction": "up" } }
        ]
      }
    },
    {
      "id": "L05", "name": "Hepatocellular panel coverage (QC)", "category": "liver",
      "parameters": [
        { "canonical": "ALT", "direction": "increase", "role": "supporting" },
        { "canonical": "AST", "direction": "increase", "role": "supporting" },
        { "canonical": "SDH", "direction": "increase", "role": "supporting" },
        { "canonical": "GDH", "direction": "increase", "role": "supporting" }
      ],
      "severity": "S1", "species_applicability": "nonclinical", "source": "Best practice",
      "baseline_aware": false,
      "applies_to_study_types": ["REPEAT_DOSE_*", "ACUTE", "DOSE_RANGE_FINDER"],
      "condition_type": "custom",
      "conditions": {
        "type": "count_present",
        "canonicals": ["ALT", "AST", "SDH", "GDH"],
        "operator": "lt",
        "value": 2
      }
    },
    {
      "id": "L06", "name": "Cholestatic panel coverage (QC)", "category": "liver",
      "parameters": [
        { "canonical": "ALP", "direction": "increase", "role": "supporting" },
        { "canonical": "GGT", "direction": "increase", "role": "supporting" },
        { "canonical": "5NT", "direction": "increase", "role": "supporting" },
        { "canonical": "TBILI", "direction": "increase", "role": "supporting" }
      ],
      "severity": "S1", "species_applicability": "nonclinical", "source": "Best practice",
      "baseline_aware": false,
      "applies_to_study_types": ["REPEAT_DOSE_*", "ACUTE", "DOSE_RANGE_FINDER"],
      "condition_type": "custom",
      "conditions": {
        "type": "count_present",
        "canonicals": ["ALP", "GGT", "5NT", "TBILI"],
        "operator": "lt",
        "value": 2
      }
    },
    {
      "id": "L07", "name": "Concurrent transaminase + bilirubin elevation (adapted from clinical Hy's Law)", "category": "liver",
      "parameters": [
        { "canonical": "ALT", "direction": "increase", "role": "required" },
        { "canonical": "TBILI", "direction": "increase", "role": "required" },
        { "canonical": "ALP", "direction": "increase", "role": "supporting" }
      ],
      "severity": "S4", "species_applicability": "both", "source": "Adapted from FDA Hy's Law guidance (clinical concept)",
      "baseline_aware": true,
      "applies_to_study_types": ["REPEAT_DOSE_*", "ACUTE", "DOSE_RANGE_FINDER"],
      "condition_type": "custom",
      "conditions": {
        "type": "and",
        "conditions": [
          {
            "type": "or",
            "conditions": [
              { "type": "direction", "canonical": "ALT", "direction": "up" },
              { "type": "direction", "canonical": "AST", "direction": "up" }
            ]
          },
          { "type": "direction", "canonical": "TBILI", "direction": "up" },
          { "type": "not", "condition": { "type": "direction", "canonical": "ALP", "direction": "up" } },
          {
            "type": "or",
            "conditions": [
              {
                "type": "and",
                "conditions": [
                  { "type": "direction", "canonical": "ALT", "direction": "up" },
                  { "type": "share_sex", "canonical_a": "ALT", "canonical_b": "TBILI" }
                ]
              },
              {
                "type": "and",
                "conditions": [
                  { "type": "direction", "canonical": "AST", "direction": "up" },
                  { "type": "share_sex", "canonical_a": "AST", "canonical_b": "TBILI" }
                ]
              }
            ]
          }
        ]
      }
    },
