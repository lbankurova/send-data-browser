      "direction": "up",
      "description": "ALT/AST elevation (ionizable lipid-mediated hepatocyte disruption)",
      "typical_magnitude": "2-5x at high IV doses; minimal for IM",
      "severity_threshold": "Self-limiting (<72h resolution, no necrosis) = non-adverse. Sustained >7 days or with hepatocyte necrosis = adverse.",
      "species_applicability": [
        "RAT",
        "MONKEY"
      ],
      "component_attribution": "ionizable_lipid",
      "route_applicability": [
        "IV"
      ],
      "time_course": {
        "onset_hours": 6,
        "peak_hours": 24,
        "expected_resolution_days": 3,
        "self_limiting": true
      },
      "rationale": "ApoE/LDLR-mediated hepatocyte uptake of LNP; ionizable lipid disrupts endosomal membrane. Biodegradable lipids (SM-102, ALC-0315) show reduced hepatotoxicity vs non-biodegradable MC3."
