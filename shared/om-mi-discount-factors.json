{
  "_meta": {
    "version": "1.0",
    "date": "2026-04-03",
    "description": "OM-without-MI corroboration discount factors. Applied to evidence score of OM-domain findings when organ was NOT microscopically examined (MI status c). 1.0 = no discount. 0.5 = strong discount.",
    "calibration_note": "Expert consensus estimates derived from literature on organ-specific MI sensitivity. NOT empirically calibrated. Species-specific differences of 0.05 are qualitative assessments.",
    "sub_factor_semantics": "The composite 'discount', 'detection_sensitivity', and 'isolation_plausibility' are THREE INDEPENDENT expert estimates. The composite is NOT derived from sub-factors by formula.",
    "sources": [
      "Sellers et al. 2007 (STP, Toxicol Pathol 35:751-755)",
      "Michael et al. 2007 (STP, Toxicol Pathol 35:742-750)",
      "Bolon et al. 2013 (STP, Toxicol Pathol 41:1028-1048)",
      "Palazzi et al. 2022 (STP, Toxicol Pathol 50:432-465)",
      "Lanning et al. 2002 (STP, Toxicol Pathol 30:524-533)",
      "Elmore 2006 (Toxicol Pathol 34:656-665)",
      "Everds et al. 2013 (Toxicol Pathol 41:805-816)",
      "Hall et al. 2012 (3rd ESTP Workshop, Toxicol Pathol 40:971-994)",
      "ICH S8 (2005)",
      "RITA/NACAD trimming guides (2003-2004)"
    ],
    "application_rules": {
      "applies_when": "OM-domain finding AND MI status is (c) organ NOT examined",
      "does_not_apply": [
        "MI status (a): positive MI findings exist for organ",
        "MI status (b): organ on tissue list but no MI entries (examined-normal)",
        "LB corroboration exists (e.g., liver OM + ALT elevation)"
      ]
    }
  },
