# ── Internal docs ──
# docs/_internal/ is a git submodule pointing to pcc-internal-docs (private repo)
docs/scientific-logic.md

# ── Development tooling (not public) ──
# .claude/ is per-user except for project conventions: settings.json (shared
# permissions/hooks) and rules/*.md (declared "loaded every session" in
# CLAUDE.md, so must travel with the repo for the load chain to work on
# fresh clones and for other agents).
.claude/*
!.claude/settings.json
!.claude/rules/
.planning/
.continue-here.md
CLAUDE.md

# ── Internal reports / audits at root ──
AUDIT_*.md
INTEGRATION_TEST_RESULTS.md

# Slack update state (local only)
.slack-update.json

# Windows artifacts
nul
.lattice/commit.lock/

# Migration-diff snapshots (transient; ~40 MB per set, captured for one-shot diff generation)
.lattice/fct-lb-bw-pre-append-snapshots/
