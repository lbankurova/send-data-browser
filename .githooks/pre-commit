#!/bin/bash
#
# Pre-commit hook: runs frontend tests, build, and complexity advisories.
# Tests/build failures abort the commit. Complexity warnings are advisory.
#
# Install: cp hooks/pre-commit <project>/.git/hooks/pre-commit && chmod +x <project>/.git/hooks/pre-commit
#

REPO_ROOT="$(git rev-parse --show-toplevel)"
FRONTEND_DIR="$REPO_ROOT/frontend"

# Pre-compute staged file stats (used by multiple steps)
STAGED_FILES=$(git diff --cached --name-only)
CODE_FILE_COUNT=$(echo "$STAGED_FILES" | grep -cE '\.(py|ts|tsx|js|jsx)$' || true)

# Staging-drift detection: capture the staged-file set at hook entry. After
# all checks complete (build/tests take >10s), we re-snapshot and BLOCK if
# files were added during the hook run -- typically caused by concurrent
# autopilot `git add` interleaving with manual commits. Two confirmed
# conflation events in this codebase (commits 1370c103 and 521f1d16) shipped
# unrelated work bundled with mismatched messages. See decisions.log entries
# tagged `history-annotation`/`CONFLATED-COMMIT`.
INITIAL_STAGED_SNAPSHOT=$(echo "$STAGED_FILES" | sort)

echo "========================================"
echo "  Pre-commit hook: running checks..."
echo "========================================"
echo ""

# --- Step -1: Commit-lock acquisition (BLOCKS on concurrent commits) ---
# Universal commit serialization. The first pre-commit to enter holds
# `.lattice/commit.lock/`; concurrent commits queue (--poll, 30s interval,
# 10min max) or block. Lock is released on EXIT via trap.
#
# Outer-held lock (LATTICE_LOCK_HOLDER): when an enclosing workflow
# (autopilot, /lattice:review, manual scripted commit) acquires the lock
# BEFORE running `git add` -- the correct discipline -- it sets
# LATTICE_LOCK_HOLDER=<holder-name> in the environment. This pre-commit
# checks the lock metadata; if the holder matches LATTICE_LOCK_HOLDER, we
# DO NOT re-acquire and DO NOT release on exit. The outer workflow owns
# the lock lifecycle. This avoids the deadlock where the outer workflow
# holds the lock and the pre-commit blocks waiting to acquire it.
LOCK_SCRIPT="$REPO_ROOT/scripts/acquire-lock.sh"
RELEASE_SCRIPT="$REPO_ROOT/scripts/release-lock.sh"
LOCK_DIR="$REPO_ROOT/.lattice/commit.lock"
LOCK_HELD_BY_HOOK=0
LOCK_OUTER_OWNED=0
if [ -x "$LOCK_SCRIPT" ] && [ -x "$RELEASE_SCRIPT" ]; then
    echo "--- Step -1: Commit lock ---"
    if [ -n "${LATTICE_LOCK_HOLDER:-}" ] && [ -f "$LOCK_DIR/meta" ]; then
        HELD_BY=$(grep -E "^holder:" "$LOCK_DIR/meta" | sed 's/holder:[[:space:]]*//')
        if [ "$HELD_BY" = "$LATTICE_LOCK_HOLDER" ]; then
            LOCK_OUTER_OWNED=1
            echo "  Lock held by outer workflow: $LATTICE_LOCK_HOLDER (skipping re-acquire)"
            echo ""
        fi
    fi
    if [ "$LOCK_OUTER_OWNED" = "0" ]; then
        HOLDER="pre-commit-pid-$$"
        if (cd "$REPO_ROOT" && bash "$LOCK_SCRIPT" "$HOLDER" --poll); then
            LOCK_HELD_BY_HOOK=1
            trap '[ "$LOCK_HELD_BY_HOOK" = "1" ] && (cd "$REPO_ROOT" && bash "$RELEASE_SCRIPT" >/dev/null 2>&1 || true)' EXIT INT TERM
            echo ""
        else
            echo ""
            echo "  COMMIT BLOCKED: could not acquire commit lock after polling."
            echo "  Another commit is in progress and exceeded the poll-wait window."
            echo "  Resolve: wait for the other commit to finish, or check"
            echo "  .lattice/commit.lock/meta to identify the holder. If stale,"
            echo "  delete .lattice/commit.lock/ manually and retry."
            echo ""
            echo "  If your workflow already acquired the lock externally, set"
            echo "  LATTICE_LOCK_HOLDER=<your-holder-name> matching the metadata"
            echo "  to skip re-acquisition in this hook."
            exit 1
        fi
    fi
else
    echo "--- Step -1: Commit lock (SKIPPED: scripts/acquire-lock.sh not found) ---"
    echo "  Concurrent commits are NOT serialized in this repo."
    echo ""
fi

# --- Step -0.5: Commit-intent declared-set check (BLOCKS on conflation) ---
# Reads .lattice/commit-intent.txt and verifies the staged set matches the
# session's declared intent. Catches the autopilot-vs-manual-staging
# conflation pattern documented in feedback_concurrent_autopilot_staging.md
# and four CONFLATED-COMMIT annotations in .lattice/decisions.log
# (1370c103, 521f1d16, a47ee865, abdb31c9).
#
# Strict from day one: missing intent file = BLOCK. The earlier Step -1
# commit-lock catches concurrent COMMITS, not concurrent STAGING -- the
# index is global per repo, so files staged by a parallel session before
# this commit ran already corrupted the staged set. This check is the
# remaining gap.
#
# Exact paths only: globs would re-introduce the failure mode by making
# unexpected files "expected by pattern". Use scripts/declare-commit-intent.sh
# --add for genuine in-flight scope additions.

INTENT_FILE="$REPO_ROOT/.lattice/commit-intent.txt"

if [ ! -f "$INTENT_FILE" ]; then
    echo "========================================"
    echo "  COMMIT BLOCKED: No commit-intent file declared."
    echo "========================================"
    echo ""
    echo "  Per the autopilot-vs-manual-staging conflation failure mode"
    echo "  (4 documented occurrences -- see CONFLATED-COMMIT annotations in"
    echo "  .lattice/decisions.log and feedback_concurrent_autopilot_staging.md),"
    echo "  every commit must declare its intended file set BEFORE 'git add'."
    echo "  Pre-commit then verifies the staged set hasn't been polluted by a"
    echo "  concurrent session's git add."
    echo ""
    echo "  Resolve:"
    echo "    bash scripts/declare-commit-intent.sh <topic> <files...>"
    echo "    git add <files...>"
    echo "    git commit -m '...'"
    echo ""
    echo "  Helpers:"
    echo "    bash scripts/declare-commit-intent.sh --add <files...>     # extend"
    echo "    bash scripts/declare-commit-intent.sh --show               # inspect"
    echo "    bash scripts/declare-commit-intent.sh --clear              # reset"
    exit 1
fi

# Parse intent file: skip blank lines + comments + KEY:VALUE headers.
# Any other non-blank line is a declared file path.
INTENT_PATHS=$(grep -v '^[[:space:]]*#' "$INTENT_FILE" \
    | grep -vE '^[A-Za-z][A-Za-z0-9_-]*:' \
    | grep -v '^[[:space:]]*$' \
    | sort -u || true)
STAGED_PATHS=$(echo "$STAGED_FILES" | grep -v '^[[:space:]]*$' | sort -u || true)

# Set difference: staged - intent (UNEXPECTED, blocking) and intent - staged
# (DECLARED_NOT_STAGED, advisory). bash process-substitution + comm.
UNEXPECTED=$(comm -23 <(echo "$STAGED_PATHS") <(echo "$INTENT_PATHS") | grep -v '^[[:space:]]*$' || true)
DECLARED_NOT_STAGED=$(comm -13 <(echo "$STAGED_PATHS") <(echo "$INTENT_PATHS") | grep -v '^[[:space:]]*$' || true)

INTENT_COUNT=$(echo "$INTENT_PATHS" | grep -cv '^[[:space:]]*$' || true)
HOLDER_LINE=$(grep -E '^Holder:' "$INTENT_FILE" 2>/dev/null | head -1 | sed 's/Holder:[[:space:]]*//')
TOPIC_LINE=$(grep -E '^Topic:' "$INTENT_FILE" 2>/dev/null | head -1 | sed 's/Topic:[[:space:]]*//')

if [ -n "$UNEXPECTED" ]; then
    UNEXP_COUNT=$(echo "$UNEXPECTED" | grep -cv '^[[:space:]]*$' || true)
    echo "========================================"
    echo "  COMMIT BLOCKED: $UNEXP_COUNT staged file(s) NOT in commit intent."
    echo "========================================"
    echo ""
    echo "  Intent declared by holder='${HOLDER_LINE:-<unknown>}' topic='${TOPIC_LINE:-<unknown>}':"
    echo "$INTENT_PATHS" | sed 's/^/    /'
    echo ""
    echo "  Unexpected staged file(s) (likely from a concurrent session):"
    echo "$UNEXPECTED" | sed 's/^/    /'
    echo ""
    echo "  This is the autopilot-vs-manual-staging conflation pattern."
    echo "  Precedents: 1370c103, 521f1d16, a47ee865, abdb31c9 (see"
    echo "  CONFLATED-COMMIT rows in .lattice/decisions.log)."
    echo ""
    echo "  Resolve options:"
    echo "    1. The unexpected files genuinely belong here (deliberate"
    echo "       in-flight scope addition):"
    echo "       bash scripts/declare-commit-intent.sh --add <file1> <file2> ..."
    echo "    2. Concurrent-session pollution -- unstage the unexpected files:"
    echo "       git restore --staged <file1> <file2> ..."
    echo "       (then optionally pause the concurrent session before retrying)"
    echo ""
    echo "  See feedback_concurrent_autopilot_staging.md for failure-mode"
    echo "  history. Step -1 commit-lock catches concurrent COMMITS;"
    echo "  this Step -0.5 catches concurrent STAGING."
    exit 1
fi

if [ -n "$DECLARED_NOT_STAGED" ]; then
    DNS_COUNT=$(echo "$DECLARED_NOT_STAGED" | grep -cv '^[[:space:]]*$' || true)
    echo "--- Step -0.5: Commit intent (WARN: $DNS_COUNT declared-not-staged) ---"
    echo "  Intent verified for $INTENT_COUNT path(s); these are declared but"
    echo "  not currently staged (split-commit / partial-commit is permitted):"
    echo "$DECLARED_NOT_STAGED" | sed 's/^/    /'
    echo ""
else
    STAGED_COUNT=$(echo "$STAGED_PATHS" | grep -cv '^[[:space:]]*$' || true)
    echo "--- Step -0.5: Commit intent verified ($STAGED_COUNT file(s); topic=${TOPIC_LINE:-<n/a>}) ---"
    echo ""
fi

# --- Step 0: Review gate check (BLOCKS if review not run) ---
# /lattice:review writes .lattice/review-gate.json when it passes.
# This check BLOCKS commits if the gate file is missing or stale.
# Small commits (<= 3 code files) get a warning; larger ones are blocked.

GATE_FILE="$REPO_ROOT/.lattice/review-gate.json"
GATE_MAX_AGE=1800  # 30 minutes

if [ -f "$GATE_FILE" ]; then
    # Check staleness
    GATE_TIME=$(stat -c %Y "$GATE_FILE" 2>/dev/null || stat -f %m "$GATE_FILE" 2>/dev/null || echo 0)
    NOW=$(date +%s)
    GATE_AGE=$((NOW - GATE_TIME))

    if [ "$GATE_AGE" -gt "$GATE_MAX_AGE" ]; then
        echo "========================================"
        echo "  REVIEW GATE: Gate file is stale (${GATE_AGE}s old, max ${GATE_MAX_AGE}s)."
        echo "  Re-run /lattice:review before committing."
        echo "========================================"
        exit 1
    fi

    echo "--- Review gate: PASS (age: ${GATE_AGE}s) ---"
    # Surface attestations recorded in the gate (SIMPLIFY-1 unified format).
    # Validation already happened at write-review-gate.sh time; this is purely
    # informational so the committer can see what F3/F6/F7 etc. attached.
    if command -v python > /dev/null 2>&1; then
        export _GATE_FILE_DISPLAY="$GATE_FILE"
        ATTESTATION_DISPLAY=$(PYTHONIOENCODING=utf-8 python << 'PYEOF'
import json, os, sys
try:
    with open(os.environ["_GATE_FILE_DISPLAY"], "r", encoding="utf-8") as fh:
        gate = json.load(fh)
except Exception:
    sys.exit(0)
attestations = gate.get("attestations") or []
if not isinstance(attestations, list) or not attestations:
    sys.exit(0)
print("  Attestations on this gate (%d):" % len(attestations))
for entry in attestations:
    if not isinstance(entry, dict):
        continue
    print("    - kind=%s ref=%s verdict=%s" % (
        entry.get("kind"), entry.get("ref"), entry.get("verdict"),
    ))
PYEOF
        )
        unset _GATE_FILE_DISPLAY
        if [ -n "$ATTESTATION_DISPLAY" ]; then
            echo "$ATTESTATION_DISPLAY"
        fi
    fi
    echo ""
else
    echo "========================================"
    echo "  COMMIT BLOCKED: No review gate found."
    echo ""
    echo "  Every commit requires /lattice:review to pass first."
    echo "  Run /lattice:review -- it writes the gate file when all checks pass."
    echo ""
    echo "  For trivial commits (docs-only, typo, comment):"
    echo "  bash scripts/write-review-gate.sh pass \"trivial fix\""
    echo "========================================"
    exit 1
fi

# --- Step 0c: Algorithmic peer-review attestation (F3 -- BLOCKS) ---
# When staged files match .lattice/algorithm-paths.txt (or the same default
# regex used by write-review-gate.sh's LATTICE_ALGORITHM_CHECK enforcement),
# the gate MUST carry at least one attestation with kind=peer-review.
# Per spec §5.3 acceptance criterion 1: 100% of algorithmic-path commits
# have a peer-review verdict in decisions.log -- this is the mechanical
# enforcement of that criterion. The skill-side wiring lives in
# commands/lattice/review.md (Agent D) and commands/lattice/peer-review.md
# (Algorithmic-Tightening Requirements section); the attestation itself is
# composed via scripts/append-attestation.sh peer-review BEFORE
# write-review-gate.sh runs.

ALGO_PATHS_FILE="$REPO_ROOT/.lattice/algorithm-paths.txt"
ALGO_REGEX_PRECOMMIT=""
if [ -f "$ALGO_PATHS_FILE" ]; then
    while IFS= read -r aline; do
        [ -z "$aline" ] && continue
        [ "${aline:0:1}" = "#" ] && continue
        afrag=$(echo "$aline" | sed 's|/|\\/|g; s|\*\*|.*|g; s|\*|[^/]*|g')
        if [ -z "$ALGO_REGEX_PRECOMMIT" ]; then
            ALGO_REGEX_PRECOMMIT="$afrag"
        else
            ALGO_REGEX_PRECOMMIT="$ALGO_REGEX_PRECOMMIT|$afrag"
        fi
    done < "$ALGO_PATHS_FILE"
else
    ALGO_REGEX_PRECOMMIT='derive-summaries\.ts|endpoint-confidence\.ts|findings-rail-engine\.ts|cross-domain-syndromes\.ts|syndrome-rules\.ts|backend/services/analysis/.*\.py'
fi

STAGED_ALGO=$(echo "$STAGED_FILES" | grep -cE "$ALGO_REGEX_PRECOMMIT" || true)
if [ "$STAGED_ALGO" -gt 0 ] && [ -f "$GATE_FILE" ]; then
    echo "--- Step 0c: Algorithmic peer-review attestation (F3) ---"
    if python "$REPO_ROOT/scripts/check-attestation-kind.py" --gate "$GATE_FILE" --kind peer-review --min 1 2>&1 | sed 's/^/  /'; then
        echo ""
    else
        echo ""
        echo "  COMMIT BLOCKED: $STAGED_ALGO algorithmic-paths file(s) staged but no kind=peer-review attestation in the gate."
        echo ""
        echo "  Per CLAUDE.md rule 19 + spec §5.3: every commit touching algorithmic"
        echo "  code requires a blind scientific peer-review verdict (SOUND /"
        echo "  CONDITIONAL / FLAWED / INSUFFICIENT) recorded as a SIMPLIFY-1"
        echo "  attestation in .lattice/review-gate.json."
        echo ""
        echo "  Resolve:"
        echo "    1. Run /lattice:peer-review on the algorithmic change. The skill"
        echo "       follows the Algorithmic-Tightening Requirements section in"
        echo "       commands/lattice/peer-review.md (mandatory query-knowledge.py"
        echo "       invocation, mandatory citation, blocking semantics for"
        echo "       CONDITIONAL/FLAWED)."
        echo "    2. Compose the verdict as an attestation:"
        echo "       bash scripts/append-attestation.sh peer-review \\"
        echo "         '<changed-file-summary>' SOUND \\"
        echo "         '<one-line summary citing query-knowledge fact and verdict reason>'"
        echo "    3. Re-run bash scripts/write-review-gate.sh \"pass\" \"...\" so the"
        echo "       gate captures the attestation."
        echo "    4. Re-attempt the commit."
        echo ""
        echo "  /lattice:review Step 1 Agent D launches peer-review automatically"
        echo "  on algorithmic-paths commits and persists the attestation. If the"
        echo "  full review skill ran, this check is satisfied without manual steps."
        exit 1
    fi
fi

# --- Step 0d: Bug-pattern propagation attestation (F6 -- BLOCKS) ---
# Per spec §8: when staged files match a registered pattern's applies_to glob,
# the gate MUST carry a kind=bug-pattern attestation referencing that pattern.
# scripts/audit-bug-patterns.py --staged-check enumerates which patterns fire
# for the current staged set; we then call check-attestation-kind.py once per
# firing pattern to require the attestation.

if [ -f "$REPO_ROOT/scripts/audit-bug-patterns.py" ] \
    && [ -f "$REPO_ROOT/docs/_internal/knowledge/bug-patterns.md" ] \
    && [ -f "$REPO_ROOT/scripts/check-attestation-kind.py" ] \
    && [ -f "$GATE_FILE" ]; then
    F6_RESULT=$(python "$REPO_ROOT/scripts/audit-bug-patterns.py" --staged-check 2>/dev/null || true)
    if [ -n "$F6_RESULT" ]; then
        echo "--- Step 0d: Bug-pattern propagation attestation (F6) ---"
        F6_BLOCKED=0
        # Parse output: each line is "<pattern>\t<count>\t<files,...>"
        while IFS=$'\t' read -r PATTERN_NAME PATTERN_COUNT PATTERN_FILES; do
            [ -z "$PATTERN_NAME" ] && continue
            if ! python "$REPO_ROOT/scripts/check-attestation-kind.py" \
                --gate "$GATE_FILE" \
                --kind bug-pattern \
                --ref "$PATTERN_NAME" \
                --min 1 --quiet 2>/dev/null; then
                if [ "$F6_BLOCKED" = "0" ]; then
                    echo "  COMMIT BLOCKED: staged files match registered bug pattern(s) without bug-pattern attestation."
                    echo ""
                    echo "  For each fired pattern, /ops:bug-stress Step 3 (pattern search)"
                    echo "  must produce one of these attestations:"
                    echo ""
                fi
                F6_BLOCKED=1
                echo "    Pattern: $PATTERN_NAME"
                echo "    Staged matches ($PATTERN_COUNT): $PATTERN_FILES"
                echo "    Compose:"
                echo "      bash scripts/append-attestation.sh bug-pattern \\"
                echo "        $PATTERN_NAME \\"
                echo "        '<verified-not-applicable | applies-to-fixed-here | applies-to-no-instance>' \\"
                echo "        '<one-line evidence: which staged file the pattern affects, and how this commit handles it>'"
                echo ""
            else
                echo "  PASS: $PATTERN_NAME (matches $PATTERN_COUNT file(s); attestation present)"
            fi
        done <<< "$F6_RESULT"
        if [ "$F6_BLOCKED" = "1" ]; then
            echo "  See docs/_internal/knowledge/bug-patterns.md for each pattern's"
            echo "  root_cause + representative_instances + prevention guidance."
            exit 1
        fi
        echo ""
    fi
fi

# --- Step 0e: F4 approval-test diff (BLOCKS on scientific-tier diff) ---
# Per spec section 6: every analytical-paths commit must diff each captured
# study baseline against the engine's current generated output. Scientific
# tier diffs block unless a written rationale (env var or
# .lattice/pending-approval-rationale.json) passes the F4 rationale contract
# (Review-3: required fields, length minimums, non-trivial, not-duplicate-of-
# recent). Presentation-tier diffs auto-log to .lattice/approval-log.tsv.

if [ "$STAGED_ALGO" -gt 0 ] && [ -d "$REPO_ROOT/backend/tests/approval-baselines" ] \
    && [ -f "$REPO_ROOT/scripts/diff-approval-baseline.py" ]; then
    echo "--- Step 0e: F4 approval-test diff ---"
    F4_BLOCKED=0
    F4_RAN=0
    for SB in "$REPO_ROOT"/backend/tests/approval-baselines/*/baseline.json; do
        [ -f "$SB" ] || continue
        SDIR="$(dirname "$SB")"
        SID="$(basename "$SDIR")"
        [ "$SID" = "_example" ] && continue
        F4_RAN=$((F4_RAN + 1))
        F4_OUT=$(python "$REPO_ROOT/scripts/diff-approval-baseline.py" "$SID" --staleness-check 2>&1)
        F4_RC=$?
        echo "$F4_OUT" | sed 's/^/  /'
        if [ "$F4_RC" -ne 0 ]; then
            F4_BLOCKED=1
        fi
    done
    if [ "$F4_RAN" = "0" ]; then
        echo "  (no captured baselines yet -- skipping F4 diff)"
    fi
    if [ "$F4_BLOCKED" = "1" ]; then
        echo ""
        echo "  COMMIT BLOCKED: scientific-tier diff present without acceptable rationale."
        echo ""
        echo "  Per spec section 6 (F4): every change to analytical output requires a"
        echo "  written rationale. Provide via:"
        echo "    1. Write the rationale JSON to .lattice/pending-approval-rationale.json"
        echo "       (sticky single-shot file; consumed on accept)"
        echo "    2. Re-attempt the commit"
        echo ""
        echo "  Required JSON shape (also accepts key:value lines):"
        echo "    {\"study\": \"<study-id>\","
        echo "     \"category\": \"noael_per_endpoint_sex\" or \"*\","
        echo "     \"summary_old_new\": \"BW NOAEL 20 -> 80 mg/kg both sexes\","
        echo "     \"rationale_text\": \"<>=40 chars, >=4 distinct word tokens, not trivial>\"}"
        echo ""
        echo "  If the diff is unintended (algorithmic change you did not author),"
        echo "  re-capture the baseline:"
        echo "    python scripts/capture-approval-baseline.py <study-id>"
        echo "  -- but do this only when you have verified the new output is correct."
        exit 1
    fi
    echo ""
fi

# --- Step 0f: Validation harness regression check (BLOCKS on algorithmic-path commits) ---
# When algorithmic-path files are staged but no frontend file is, Step 1's
# `npm test` does NOT fire -- so the validation harness (which compares engine
# output to docs/validation/references/*.yaml ground truth) wouldn't run and a
# backend-only engine change could ship without the harness checking it.
# This step closes that gap. Skipped when STAGED_FRONTEND > 0 because Step 1
# already covers it.
#
# This is CLAUDE.md rule 19 with teeth: the harness fails on regression vs the
# .assertion-baseline.json snapshot. New assertion failures (study + type +
# description that wasn't in the baseline) print and abort the commit.
#
# Failure mode prevented: GAP-304 retro -- a backend engine change that would
# have produced "insufficient evidence" on PointCross while the reference card
# asserts mortality_loael=3 + HCC concordance.

if [ "$STAGED_ALGO" -gt 0 ] && [ "$STAGED_FRONTEND" -eq 0 ]; then
    echo "--- Step 0f: Validation harness regression check ---"
    echo "  $STAGED_ALGO algorithmic-paths file(s) staged; running validation harness"
    echo "  (compares engine output to docs/validation/references/*.yaml ground truth)."
    echo ""

    if (cd "$FRONTEND_DIR" && npx vitest run tests/generate-validation-docs.test.ts 2>&1); then
        echo ""
        echo "  Validation harness passed -- no regressions vs .assertion-baseline.json."
        echo ""
    else
        echo ""
        echo "========================================"
        echo "  COMMIT BLOCKED: validation harness detected a regression."
        echo "  Engine output diverged from a reference-card assertion that"
        echo "  was not in .assertion-baseline.json."
        echo ""
        echo "  Resolve (in order of preference):"
        echo "    1. Fix the engine bug. The regression line above names the"
        echo "       study, assertion type, and description."
        echo "    2. If the reference card is wrong (rare -- requires evidence),"
        echo "       update docs/validation/references/<study>.yaml and document"
        echo "       why in the commit message."
        echo "    3. If the new failure is genuinely intended and accepted,"
        echo "       refresh the baseline:"
        echo "         cd frontend && UPDATE_BASELINE=1 npx vitest run tests/generate-validation-docs.test.ts"
        echo "       Stage the updated .assertion-baseline.json and explain in"
        echo "       the commit message why the change was accepted."
        echo "========================================"
        exit 1
    fi
fi

# --- Step 0b: Doc generator freshness (BLOCKS if stale) ---
# Checks that the 3 doc generators were run after source changes.
# Only blocks if engine/analysis files are staged (the files that
# actually cause doc output to change).

ENGINE_STAGED=$(echo "$STAGED_FILES" | grep -cE "(classification\.py|findings_pipeline\.py|statistics\.py|view_dataframes\.py|domain_stats\.py|scores_and_rules\.py|confidence\.py|findings-rail-engine\.ts|derive-summaries\.ts|cross-domain-syndromes\.ts|endpoint-confidence\.ts|finding-nature\.ts|organ-weight-normalization\.ts|syndrome-interpretation\.ts)" || true)

if [ "$ENGINE_STAGED" -gt 0 ]; then
    DOC_STALE=false
    DOC_STALE_FILES=""

    # Check coverage-facts.md — generated by generate-coverage-facts.py
    if [ -f "$REPO_ROOT/docs/coverage-facts.md" ]; then
        FACTS_STAGED=$(echo "$STAGED_FILES" | grep -c "coverage-facts.md" || true)
        if [ "$FACTS_STAGED" -eq 0 ]; then
            DOC_STALE=true
            DOC_STALE_FILES="${DOC_STALE_FILES}  - docs/coverage-facts.md (run: generate-coverage-facts.py)\n"
        fi
    fi

    # Check validation docs — generated by ground-truth-validation test
    VALIDATION_STAGED=$(echo "$STAGED_FILES" | grep -cE "docs/validation/" || true)
    if [ "$VALIDATION_STAGED" -eq 0 ]; then
        DOC_STALE=true
        DOC_STALE_FILES="${DOC_STALE_FILES}  - docs/validation/*.md (run: vitest run ground-truth-validation)\n"
    fi

    if [ "$DOC_STALE" = true ]; then
        echo "========================================"
        echo "  COMMIT BLOCKED: Doc generators not run."
        echo ""
        echo "  Engine files are staged but generated docs are not:"
        echo -e "$DOC_STALE_FILES"
        echo "  Run all 3 doc generators (COMMIT-CHECKLIST item 7):"
        echo "    1. backend/venv/Scripts/python.exe scripts/generate-coverage-facts.py"
        echo "    2. cd frontend && npx vitest run generate-engine-reference"
        echo "    3. cd frontend && npx vitest run ground-truth-validation"
        echo "  Then stage the generated output."
        echo "========================================"
        exit 1
    fi

    echo "--- Doc freshness: Engine files staged, generated docs also staged. PASS ---"
    echo ""
fi

# --- Step 1: Frontend tests (if frontend changed) ---
STAGED_FRONTEND=$(echo "$STAGED_FILES" | grep -c "^frontend/" || true)
if [ "$STAGED_FRONTEND" -gt 0 ]; then
    echo "--- Step 1/4: Running frontend tests (npm test) ---"
    echo ""

    if (cd "$FRONTEND_DIR" && npm test); then
        echo ""
        echo "--- Tests passed. ---"
        echo ""
    else
        echo ""
        echo "========================================"
        echo "  COMMIT ABORTED: Frontend tests failed."
        echo "  Fix the failing tests before committing."
        echo "========================================"
        exit 1
    fi

    # --- Step 2: Frontend build ---
    echo "--- Step 2/4: Running frontend build (npm run build) ---"
    echo ""

    if (cd "$FRONTEND_DIR" && npm run build); then
        echo ""
        echo "--- Build passed. ---"
        echo ""
    else
        echo ""
        echo "========================================"
        echo "  COMMIT ABORTED: Frontend build failed."
        echo "  Fix TypeScript / build errors before committing."
        echo "========================================"
        exit 1
    fi
else
    echo "No frontend changes staged -- skipping frontend checks."
    echo ""
fi

# --- Step 3: Index freshness checks (warnings, blocking on MANIFEST) ---
echo "--- Step 3/4: Index freshness checks ---"
echo ""

INDEX_WARNINGS=""

# 3a: MANIFEST staleness — if staged files appear in MANIFEST dependencies, MANIFEST should be staged too
if [ -f "$REPO_ROOT/docs/_internal/MANIFEST.md" ]; then
    MANIFEST_STAGED=$(echo "$STAGED_FILES" | grep -c "MANIFEST.md" || true)
    if [ "$MANIFEST_STAGED" -eq 0 ]; then
        # Check if any staged file is a MANIFEST dependency
        MANIFEST_DEPS=""
        while IFS= read -r SF; do
            [ -z "$SF" ] && continue
            BASENAME=$(basename "$SF")
            if grep -q "$BASENAME" "$REPO_ROOT/docs/_internal/MANIFEST.md" 2>/dev/null; then
                MANIFEST_DEPS="${MANIFEST_DEPS}    ${SF}\n"
            fi
        done <<< "$STAGED_FILES"
        if [ -n "$MANIFEST_DEPS" ]; then
            INDEX_WARNINGS="${INDEX_WARNINGS}  MANIFEST: These staged files are MANIFEST dependencies but MANIFEST.md was not updated:\n${MANIFEST_DEPS}  Update 'Last validated' date in MANIFEST.md, or mark specs as STALE.\n\n"
        fi
    fi
fi

# 3b: TODO.md freshness — large changes should update TODO
if [ "$CODE_FILE_COUNT" -gt 3 ]; then
    TODO_STAGED=$(echo "$STAGED_FILES" | grep -c "TODO.md" || true)
    if [ "$TODO_STAGED" -eq 0 ]; then
        INDEX_WARNINGS="${INDEX_WARNINGS}  TODO.md: ${CODE_FILE_COUNT} code files changed but TODO.md was not updated.\n  Large changes usually resolve or create TODO items. Review docs/_internal/TODO.md.\n\n"
    fi
fi

# 3c: Spec archival — if commit message references an incoming/ spec, it should be archived
# (Can only check staged files, not commit message — check if incoming/ files were modified but not moved)
INCOMING_MODIFIED=$(echo "$STAGED_FILES" | grep "docs/_internal/incoming/[^a]" | grep -v "archive/" || true)
if [ -n "$INCOMING_MODIFIED" ]; then
    INDEX_WARNINGS="${INDEX_WARNINGS}  INCOMING SPECS: Modified but not archived:\n"
    while IFS= read -r SPEC; do
        [ -n "$SPEC" ] && INDEX_WARNINGS="${INDEX_WARNINGS}    ${SPEC}\n"
    done <<< "$INCOMING_MODIFIED"
    INDEX_WARNINGS="${INDEX_WARNINGS}  If these specs are now implemented, move to incoming/archive/ (rule 7).\n\n"
fi

# 3d: ROADMAP freshness — if incoming/ specs were archived, ROADMAP should be updated
ARCHIVED=$(echo "$STAGED_FILES" | grep "incoming/archive/" || true)
if [ -n "$ARCHIVED" ]; then
    ROADMAP_STAGED=$(echo "$STAGED_FILES" | grep -c "ROADMAP.md" || true)
    if [ "$ROADMAP_STAGED" -eq 0 ]; then
        INDEX_WARNINGS="${INDEX_WARNINGS}  ROADMAP: Specs were archived but ROADMAP.md was not updated.\n  Mark completed items in docs/_internal/ROADMAP.md.\n\n"
    fi
fi

if [ -n "$INDEX_WARNINGS" ]; then
    echo "  Index freshness issues (non-blocking):"
    echo ""
    echo -e "$INDEX_WARNINGS"
else
    echo "  All indexes look fresh."
    echo ""
fi

# --- Step 4: Complexity advisories (warnings only, never blocks) ---
echo "--- Step 4/4: Complexity advisories ---"
echo ""

COMPLEXITY_WARNINGS=""

# 4a: File size warnings
while IFS= read -r FILE; do
    [ -z "$FILE" ] && continue
    [ ! -f "$FILE" ] && continue

    LINE_COUNT=$(wc -l < "$FILE" 2>/dev/null)
    case "$FILE" in
        *.py)
            if [ "$LINE_COUNT" -gt 500 ]; then
                COMPLEXITY_WARNINGS="${COMPLEXITY_WARNINGS}  WARNING: ${FILE} is ${LINE_COUNT} lines (Python threshold: 500)\n"
            fi
            ;;
        *.ts|*.tsx)
            if [ "$LINE_COUNT" -gt 800 ]; then
                COMPLEXITY_WARNINGS="${COMPLEXITY_WARNINGS}  WARNING: ${FILE} is ${LINE_COUNT} lines (TS/TSX threshold: 800)\n"
            fi
            ;;
    esac
done <<< "$STAGED_FILES"

# 4b: New source files without test coverage
NEW_FILES=$(git diff --cached --name-only --diff-filter=A)
while IFS= read -r FILE; do
    [ -z "$FILE" ] && continue
    case "$FILE" in
        *.test.*|*.spec.*|*__test__*|*/tests/*)
            continue  # Skip test files themselves
            ;;
        backend/*.py|frontend/src/*.ts|frontend/src/*.tsx)
            BASENAME=$(basename "$FILE" | sed 's/\.[^.]*$//')
            if ! echo "$STAGED_FILES" | grep -qE "(test|spec).*${BASENAME}|${BASENAME}.*(test|spec)"; then
                COMPLEXITY_WARNINGS="${COMPLEXITY_WARNINGS}  ADVISORY: New file ${FILE} has no corresponding test file staged\n"
            fi
            ;;
    esac
done <<< "$NEW_FILES"

# 4c: Bare lint exemptions
while IFS= read -r FILE; do
    [ -z "$FILE" ] && continue
    [ ! -f "$FILE" ] && continue
    case "$FILE" in
        *.py)
            BARE=$(git diff --cached -- "$FILE" | grep "^+" | grep "# noqa:" | grep -v "#.*noqa:.*#\|#.*noqa:.*--" || true)
            if [ -n "$BARE" ]; then
                COMPLEXITY_WARNINGS="${COMPLEXITY_WARNINGS}  WARNING: Bare # noqa: in ${FILE} -- add justification comment (CLAUDE.md rule 15)\n"
            fi
            ;;
        *.ts|*.tsx)
            BARE=$(git diff --cached -- "$FILE" | grep "^+" | grep "eslint-disable" | grep -v "//.*eslint-disable.*--\|//.*eslint-disable.*//" || true)
            if [ -n "$BARE" ]; then
                COMPLEXITY_WARNINGS="${COMPLEXITY_WARNINGS}  WARNING: Bare eslint-disable in ${FILE} -- add justification comment (CLAUDE.md rule 15)\n"
            fi
            ;;
    esac
done <<< "$STAGED_FILES"

# 4d: Science advisory
SCIENCE_FILES=$(git diff --cached --name-only -- \
    'backend/services/analysis/*.py' \
    'backend/generator/*.py' \
    'shared/rules/*.yaml' \
    'shared/rules/*.json' \
    'shared/config/*.json' \
    'shared/config/*.yaml' \
    2>/dev/null)

if [ -n "$SCIENCE_FILES" ]; then
    COMPLEXITY_WARNINGS="${COMPLEXITY_WARNINGS}\n  SCIENCE ADVISORY: The following domain-critical files changed:\n"
    while IFS= read -r SF; do
        [ -n "$SF" ] && COMPLEXITY_WARNINGS="${COMPLEXITY_WARNINGS}    $SF\n"
    done <<< "$SCIENCE_FILES"
    COMPLEXITY_WARNINGS="${COMPLEXITY_WARNINGS}  Consider: bash scripts/regenerate-validation.sh\n"
fi

if [ -n "$COMPLEXITY_WARNINGS" ]; then
    echo "  Advisories (non-blocking):"
    echo ""
    echo -e "$COMPLEXITY_WARNINGS"
    echo ""
else
    echo "  No advisories."
    echo ""
fi

# --- Step 4d: NOAEL floor co-read lint (F3, hcd-mi-ma-s08-wiring) ---
# Blocks a commit that reads clinical_confidence/hcd_evidence inside
# view_dataframes.py NOAEL-gate functions without co-consulting
# noael_floor_applied. Only runs when the guarded file is staged.

if [ -x "$REPO_ROOT/scripts/lint-noael-floor-coread.sh" ]; then
